# Supabase (obligatoire)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Stripe (obligatoire pour les paiements)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Google Maps (obligatoire pour la géolocalisation)
EXPO_PUBLIC_GOOGLE_MAPS_KEY=AIza_xxx

# Prelaunch (avant-première). 'true' = app limitée à inscription +
# dépôt d'annonces. Toute autre valeur (ou absence) = marketplace
# ouverte. À régler dans Vercel > Environment Variables.
EXPO_PUBLIC_PRELAUNCH_MODE=false
