{
  "expo": {
    "name": "LoueTonBien",
    "slug": "louetonbien",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "louetonbien",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "web": {
      "bundler": "metro",
      "output": "spa",
      "favicon": "./assets/images/LTB_favicon.png",
      "lang": "fr",
      "meta": {
        "viewport": "width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no"
      }
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://app.louetonbien.fr"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
